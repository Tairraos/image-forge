{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ImageForge",
  "version": "0.2.0",
  "identifier": "com.xiaole.imageforge",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Image Forge",
        "width": 1360,
        "height": 930,
        "minWidth": 1200,
        "minHeight": 900
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"]
  }
}
