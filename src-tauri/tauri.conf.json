{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ImageForge",
  "version": "1.0.48",
  "identifier": "com.xiaole.imageforge",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Image Forge 1.0.48",
        "width": 1360,
        "height": 930,
        "minWidth": 1200,
        "minHeight": 800
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$HOME/.image-forge/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/icon.png"
    ]
  }
}
